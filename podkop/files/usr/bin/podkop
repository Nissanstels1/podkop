    print_global "📄 WAN config"
    if uci show network.wan > /dev/null 2>&1; then
        awk '
            /^config / {
                p = ($2 == "interface" && $3 == "'\''wan'\''")
                proto = ""
            }
            p {
                if ($1 == "option" && $2 == "proto") {
                    proto = $3
                    print
                } else if (proto == "'\''static'\''" && $1 == "option" && ($2 == "ipaddr" || $2 == "netmask" || $2 == "gateway")) {
                    print "        option", $2, "'\''******'\''"
                } else if (proto == "'\''pppoe'\''" && $1 == "option" && ($2 == "username" || $2 == "password")) {
                    print "        option", $2, "'\''******'\''"
                } else {
                    print
                }
            }
        ' /etc/config/network
    else
        print_global "❌ WAN configuration not found"
    fi

    if uci show network | grep -q endpoint_host; then
        uci show network | grep endpoint_host | cut -d'=' -f2 | tr -d "'\" " | while read -r host; do
            if [ "$host" = "engage.cloudflareclient.com" ]; then
                print_global "⚠️ WARP detected: $host"
                continue
            fi

            ip_prefix=$(echo "$host" | cut -d'.' -f1,2)
            if echo "$CLOUDFLARE_OCTETS" | grep -wq "$ip_prefix"; then
                print_global "━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                print_global "⚠️ WARP detected: $host"
            fi
        done
    fi

    if uci show network | grep -q route_allowed_ips; then
        uci show network | grep "wireguard_.*\.route_allowed_ips='1'" | cut -d'.' -f1-2 | while read -r peer_section; do
            local allowed_ips
            allowed_ips=$(uci get "${peer_section}.allowed_ips" 2> /dev/null)

            if [ "$allowed_ips" = "0.0.0.0/0" ]; then
                print_global "━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                print_global "⚠️ WG Route allowed IP enabled with 0.0.0.0/0"
            fi
        done
    fi

    if [ -f "/etc/init.d/zapret" ]; then
        print_global "━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        print_global "⚠️ Zapret detected"
    fi

    print_global "━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    print_global "🥸 FakeIP status"

    local fakeip_check_json
    fakeip_check_json=$(check_fakeip)

    if [ -n "$fakeip_check_json" ]; then
        local fakeip_status

        fakeip_status=$(echo "$fakeip_check_json" | jq -r '.fakeip // false')

        if [ "$fakeip_status" = "true" ]; then
            print_global "✅ Router DNS is routed through sing-box"
        else
            print_global "⚠️ Router DNS is NOT routed through sing-box"
        fi
    else
        print_global "❌ Failed to get FakeIP info"
    fi

    local fakeip_address
    fakeip_address=$(dig +short @127.0.0.42 $FAKEIP_TEST_DOMAIN)

    if echo "$fakeip_address" | grep -q "^198\.18\."; then
        print_global "✅ Sing-box works with FakeIP: $fakeip_address"
    else
        print_global "❌ Sing-box does NOT work with FakeIP: $fakeip_address"
    fi
}

# Returns 0 if the section's filter or fast/slow split needs a fresh latency
# cache to be useful. When this returns non-zero we skip the synchronous probe
# entirely — sing-box's own internal urltest already picks the lowest-RTT
# member, which is the user's "filter disabled = shortest ping wins" behaviour.
subscription_section_needs_latency() {
    local section="$1"
    local pmin pmax pool_split
    config_get pmin       "$section" "subscription_ping_min"  "0"
    config_get pmax       "$section" "subscription_ping_max"  "0"
    config_get pool_split "$section" "subscription_pool_split" "0"

    [ "$pool_split" = "1" ] && return 0
    [ -n "$pmin" ] && [ "$pmin" != "0" ] && return 0
    [ -n "$pmax" ] && [ "$pmax" != "0" ] && return 0
    return 1
}

# Wait until sing-box's Clash API is responsive after a reload. Returns 0 once
# /proxies replies with a JSON object (i.e. the urltest groups are usable),
# 1 if it never comes up within the timeout. Quick and quiet — this runs as
# part of every scheduled subscription update.
subscription_wait_clash_api_ready() {
    local timeout="${1:-15}"
    local i=0
    while [ "$i" -lt "$timeout" ]; do
        if clash_api get_proxies 2>/dev/null | jq -e 'type == "object"' >/dev/null 2>&1; then
            return 0
        fi
        sleep 1
        i=$((i + 1))
    done
    return 1
}

# Top-level CLI entry — designed for seamless updates.
#
# Per call we trigger AT MOST ONE sing-box reload — and only when the
# subscription body genuinely changed (sha256 of upstream content differs).
# A scheduled update at "1d" interval that fetches an unchanged feed is
# completely transparent: sing-box runs uninterrupted.
#
# Latency probing (for ping-range / fast-slow split) runs after the optional
# reload, in the background relative to user traffic. The freshly-measured
# latencies feed the NEXT update cycle's filter — there is no second reload.
# This is the trade-off: filter changes propagate one cycle late, but the
# user never sees a connection blip in exchange.
#
# The pool watchdog (1-minute cron) handles the "selected profile died"
# case by switching the user-facing selector via Clash API at runtime,
# without any config rebuild.
subscription_update_cli() {
    local target="$1"
    local rc=0 any=0 need_reload=0

    # Per-section refresh: fetch + parse, decide if anything material changed.
    _refresh_one() {
        local section="$1"
        local prev_sha="" new_sha=""

        # Read the previous body sha BEFORE update_section overwrites the meta.
        prev_sha="$(subscription_meta_read "$(subscription_cache_path_meta "$section")" \
                    | awk -F'\t' '{print $5}')"

        subscription_update_section "$section" || rc=1

        new_sha="$(subscription_meta_read "$(subscription_cache_path_meta "$section")" \
                   | awk -F'\t' '{print $5}')"

        if [ -n "$new_sha" ] && [ "$new_sha" != "$prev_sha" ]; then
            need_reload=1
            log "subscription[$section]: upstream content changed (sha $prev_sha → $new_sha), will reload sing-box"
        else
            log "subscription[$section]: upstream content unchanged, sing-box stays running"
        fi
    }

    if [ -n "$target" ]; then
        any=1
        _refresh_one "$target"
    else
        _do_one_refresh() {
            local section="$1"
            local n
            n="$(subscription_collect_urls "$section" | grep -c '.' || true)"
            [ -z "$n" ] || [ "$n" = "0" ] && return 0
            any=1
            _refresh_one "$section"
        }
        config_foreach _do_one_refresh "section"
    fi

    [ "$any" -eq 1 ] || return "$rc"

    # Single reload — only when at least one section's upstream actually changed.
    if [ "$rc" -eq 0 ] && [ "$need_reload" -eq 1 ]; then
        log "subscription: reloading sing-box (subscription body changed)"
        reload >/dev/null 2>&1 || /etc/init.d/sing-box reload >/dev/null 2>&1 || true
        _persist_sig() {
            local section="$1"
            local sig
            sig="$(subscription_compute_filter_signature "$section")"
            subscription_write_applied_signature "$section" "$sig"
        }
        if [ -n "$target" ]; then
            _persist_sig "$target"
        else
            config_foreach _persist_sig "section"
        fi
    fi

    # Background latency probe (no reload). Refreshes the cache so the NEXT
    # update cycle's filter has fresh data. Skipped if no section needs it.
    if [ "$rc" -eq 0 ]; then
        local any_needs=0
        _check_needs() {
            subscription_section_needs_latency "$1" && any_needs=1
        }
        if [ -n "$target" ]; then
            _check_needs "$target"
        else
            config_foreach _check_needs "section"
        fi

        if [ "$any_needs" -eq 1 ]; then
            if subscription_wait_clash_api_ready 15; then
                _probe_one() {
                    local section="$1"
                    local n
                    n="$(subscription_collect_urls "$section" | grep -c '.' || true)"
                    [ -z "$n" ] || [ "$n" = "0" ] && return 0
                    subscription_section_needs_latency "$section" || return 0
                    log "subscription[$section]: refreshing latency cache (no reload)"
                    subscription_collect_latency_cli "$section" >/dev/null 2>&1 || \
                        log "subscription[$section]: latency probe failed" "warn"
                }
                if [ -n "$target" ]; then
                    _probe_one "$target"
                else
                    config_foreach _probe_one "section"
                fi
            else
                log "subscription: Clash API not ready, skipping latency refresh; pool watchdog will catch dead profiles" "warn"
            fi
        fi
    fi

    return "$rc"
}

subscription_status_cli() {
    local target="$1"
    if [ -n "$target" ]; then
        subscription_status_json "$target"
        return $?
    fi
    local results=""
    _emit() {
        local section="$1"
        local n
        n="$(subscription_collect_urls "$section" | grep -c '.' || true)"
        [ -z "$n" ] || [ "$n" = "0" ] && return 0
        local item
        item="$(subscription_status_json "$section")"
        if [ -z "$results" ]; then
            results="$item"
        else
            results="$results
$item"
        fi
    }
    config_foreach _emit "section"
    if [ -z "$results" ]; then
        echo "[]"
    else
        printf '%s\n' "$results" | jq -s '.'
    fi
}

subscription_list_cli() {
    local target="$1"
    if [ -z "$target" ]; then
        echo "Usage: $0 subscription_list <section>" >&2
        return 2
    fi
    subscription_list_json "$target"
}

# Refresh the per-section latency cache by calling the Clash API.
#
# We test the per-section urltest group (which sing-box already maintains for
# us) — Clash API returns each member's last delay measurement. We translate
# the sing-box outbound tag (`<section>-N`) back to the user-facing profile
# tag stored in the parsed cache so the latency file is keyed the way the
# UI/filter expects.
subscription_collect_latency_cli() {
    local target="$1"
    if [ -z "$target" ]; then
        echo "Usage: $0 subscription_collect_latency <section>" >&2
        return 2
    fi

    if [ ! -r "$(subscription_cache_path_parsed "$target")" ]; then
        log "subscription[$target]: no parsed cache, refusing to probe" "warn"
        return 1
    fi

    local urltest_tag delay_json latency_file tmp
    urltest_tag="$(get_outbound_tag_by_section "$target-urltest")"
    latency_file="$(subscription_cache_path_latency "$target")"
    tmp="${latency_file}.tmp"

    delay_json="$(clash_api get_group_latency "$urltest_tag" 5000 2>/dev/null)"
    if [ -z "$delay_json" ] || ! printf '%s' "$delay_json" \
            | jq -e 'type == "object"' >/dev/null 2>&1; then
        log "subscription[$target]: Clash API returned no latency data (group=$urltest_tag); is sing-box running?" "warn"
        return 1
    fi

    : > "$tmp"

    # delay_json is { "<sing-box outbound tag>": <ms or 0>, ... }.
    # Map sing-box tag (`<section>-N`) → user-facing profile tag (Nth line of parsed file, 1-based).
    local i=1
    while IFS= read -r line; do
        [ -z "$line" ] && continue
        local sb_tag profile_tag ms
        sb_tag="$(get_outbound_tag_by_section "$target-$i")"
        profile_tag="$(subscription_line_get_tag "$line")"
        ms="$(printf '%s' "$delay_json" | jq -r --arg t "$sb_tag" '.[$t] // empty' 2>/dev/null)"
        if [ -n "$ms" ] && [ "$ms" != "null" ]; then
            # Clash API uses 0 for "timeout / not yet measured" — record as -1 so
            # the filter treats them as "ignore for now" (passthrough).
            if [ "$ms" = "0" ]; then
                printf '%s\t-1\n' "$profile_tag" >> "$tmp"
            else
                printf '%s\t%s\n' "$profile_tag" "$ms" >> "$tmp"
            fi
        fi
        i=$((i + 1))
    done < "$(subscription_cache_path_parsed "$target")"

    mv "$tmp" "$latency_file"
    log "subscription[$target]: latency cache refreshed ($(wc -l < "$latency_file" | tr -d ' ') entries)" "info"
}

# Pool watchdog: if every member of <section>-fast is dead (latency=0 or empty)
# but <section>-slow has at least one alive member — switch the user-facing
# selector to -slow. Reverses on the next sample where -fast has a live one.
subscription_pool_watchdog_cli() {
    local target="$1"
    if [ -z "$target" ]; then
        echo "Usage: $0 subscription_pool_watchdog <section>" >&2
        return 2
    fi

    local pool_split
    config_get pool_split "$target" "subscription_pool_split" "0"
    [ "$pool_split" = "1" ] || return 0

    local selector_tag fast_tag slow_tag
    selector_tag="$(get_outbound_tag_by_section "$target")"
    fast_tag="$(get_outbound_tag_by_section "$target-fast")"
    slow_tag="$(get_outbound_tag_by_section "$target-slow")"

    # Probe both groups in parallel — Clash returns 0 for dead members.
    local fast_json slow_json fast_alive slow_alive
    fast_json="$(clash_api get_group_latency "$fast_tag" 3000 2>/dev/null)"
    slow_json="$(clash_api get_group_latency "$slow_tag" 3000 2>/dev/null)"

    fast_alive="$(printf '%s' "$fast_json" | jq -r 'to_entries | map(select(.value > 0)) | length' 2>/dev/null)"
    slow_alive="$(printf '%s' "$slow_json" | jq -r 'to_entries | map(select(.value > 0)) | length' 2>/dev/null)"
    [ -z "$fast_alive" ] && fast_alive=0
    [ -z "$slow_alive" ] && slow_alive=0

    if [ "$fast_alive" -eq 0 ] && [ "$slow_alive" -gt 0 ]; then
        log "subscription[$target]: fast pool dead, switching selector → slow" "warn"
        clash_api set_group_proxy "$selector_tag" "$slow_tag" >/dev/null 2>&1 || true
    elif [ "$fast_alive" -gt 0 ]; then
        # Make sure we aren't stuck in slow forever.
        local current
        current="$(printf '%s' "$(clash_api get_proxies 2>/dev/null)" \
            | jq -r --arg sel "$selector_tag" '.proxies[$sel].now // ""' 2>/dev/null)"
        if [ "$current" = "$slow_tag" ]; then
            log "subscription[$target]: fast pool recovered, switching selector → fast" "info"
            clash_api set_group_proxy "$selector_tag" "$fast_tag" >/dev/null 2>&1 || true
        fi
    fi
}

show_help() {
    cat << EOF
Usage: $0 COMMAND

Available commands:
    start                   Start podkop service
    stop                    Stop podkop service
    reload                  Reload podkop configuration
    restart                 Restart podkop service
    main                    Run main podkop process
    list_update             Update domain lists
    subscription_update [section]
                            Refresh subscription cache (cron-friendly).
                            Without an argument refreshes every section that
                            has subscription_url set, then reloads sing-box.
    subscription_status [section]
                            Print JSON status (last_update, total, filtered,
                            format, status) for one or all sections.
    subscription_list <section>
                            Print JSON array of all parsed profiles for the
                            given section, with a 'matched' flag per row.
    subscription_collect_latency <section>
                            Refresh the per-section latency cache by polling
                            the Clash API (used by ping-range filter and
                            fast/slow pool split). Cron-driven by default.
    subscription_pool_watchdog <section>
                            One-shot health check for the fast/slow pool
                            split — switches the selector to slow if every
                            member of the fast pool is currently dead.
    check_proxy             Check proxy connectivity
    check_nft               Check NFT rules
    check_nft_rules         Check NFT rules status
    check_sing_box          Check sing-box installation and status
    check_logs              Show podkop logs from system journal
    check_sing_box_logs     Show sing-box logs
    check_fakeip            Test FakeIP on router
    clash_api               Clash API interface for managing proxies and groups
    show_config             Display current podkop configuration
    show_version            Show podkop version
    show_sing_box_config    Show sing-box configuration
    show_sing_box_version   Show sing-box version
    show_system_info        Show system information
    get_status              Get podkop service status
    get_sing_box_status     Get sing-box service status
    get_system_info         Get system information in JSON format
    check_dns_available     Check DNS server availability
    global_check            Run global system check
EOF
}

case "$1" in
start)
    start
    ;;
stop)
    stop
    ;;
reload)
    reload
    ;;
restart)
    restart
    ;;
main)
    main
    ;;
list_update)
    list_update
    ;;
subscription_update)
    subscription_update_cli "$2"
    ;;
subscription_status)
    subscription_status_cli "$2"
    ;;
subscription_list)
    subscription_list_cli "$2"
    ;;
subscription_collect_latency)
    subscription_collect_latency_cli "$2"
    ;;
subscription_pool_watchdog)
    subscription_pool_watchdog_cli "$2"
    ;;
check_proxy)
    check_proxy
    ;;
check_nft)
    check_nft
    ;;
check_nft_rules)
    check_nft_rules
    ;;
check_sing_box)
    check_sing_box
    ;;
check_logs)
    check_logs
    ;;
check_sing_box_logs)
    check_sing_box_logs
    ;;
check_fakeip)
    check_fakeip
    ;;
clash_api)
    clash_api "$2" "$3" "$4"
    ;;
show_config)
    show_config
    ;;
show_version)
    show_version
    ;;
show_sing_box_config)
    show_sing_box_config
    ;;
show_sing_box_version)
    show_sing_box_version
    ;;
show_system_info)
    show_system_info
    ;;
get_status)
    get_status
    ;;
get_sing_box_status)
    get_sing_box_status
    ;;
get_system_info)
    get_system_info
    ;;
check_dns_available)
    check_dns_available
    ;;
global_check)
    global_check "${2:-}"
    ;;
*)
    show_help
    exit 1
    ;;
esac
